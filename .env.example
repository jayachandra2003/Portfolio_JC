# Firebase (Spark/free plan — no Storage bucket needed)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Site metadata (used in Phase 13 — SEO/OpenGraph)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Firebase Admin SDK — server-only, used by app/api/contact for writing
# messages to Firestore. Get these 3 values from the SAME
# serviceAccountKey.json used by the seed script (Phase 4): open that
# file and copy project_id, client_email, and private_key.
# NEVER prefix these with NEXT_PUBLIC_ — that would expose them to the browser.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
